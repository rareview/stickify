{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "meta": {
    "title": "Stickify Playground",
    "author": "rareview",
    "description": "Install and activate Stickify in WordPress Playground with sample post data."
  },
  "landingPage": "/wp-admin/options-general.php?page=stickify",
  "preferredVersions": {
    "php": "8.2",
    "wp": "latest"
  },
  "login": true,
  "steps": [
    {
      "step": "installTheme",
      "themeData": {
        "resource": "bundled",
        "path": "blueprint-theme.zip"
      },
      "options": {
        "activate": true,
        "targetFolderName": "blueprint-theme"
      }
    },
    {
      "step": "importWxr",
      "file": {
        "resource": "bundled",
        "path": "content/blueprint-content.xml"
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "bundled",
        "path": "stickify.zip"
      },
      "options": {
        "activate": true,
        "targetFolderName": "stickify"
      }
    },
    {
      "step": "wp-cli",
      "command": "wp option update blogname 'Stickify Playground'"
    },
    {
      "step": "wp-cli",
      "command": "wp option update blogdescription 'A WordPress plugin to make any post type sticky and schedule it.'"
    },
    {
      "step": "wp-cli",
      "command": "wp option update show_on_front page"
    },
    {
      "step": "wp-cli",
      "command": "wp option update page_on_front 998"
    },
    {
      "step": "wp-cli",
      "command": "wp option update page_for_posts 999"
    }
  ]
}
