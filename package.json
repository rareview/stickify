{
  "name": "stickify",
  "version": "1.0.0",
  "description": "Make any post type sticky",
  "engineStrict": true,
  "engines": {
    "node": ">=20.17.0",
    "npm": ">=10.0.0"
  },
  "lint-staged": {
    "/**/*.css": [
      "npm run lint:plugin:css"
    ],
    "/**/*.js": [
      "npm run lint:plugin:js"
    ],
    "/**/*.json": [
      "npm run lint:plugin:json"
    ],
    "/**/*.php": [
      "composer lint"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "scripts": {
    "setup": "npm run bootstrap && scripts/setup.js",
    "watch": "webpack --mode development --watch",
    "build": "webpack --mode production",
    "bootstrap": "npm run setup:php && npm run setup:js",
    "setup:php": "composer install",
    "setup:js": "npm install",
    "lint": "npm-run-all lint:*:*",
    "lint:plugin:css": "stylelint '**/*.scss'",
    "lint:plugin:js": "eslint '**/*.js'",
    "lint:plugin:json": "jsonlint",
    "lint:plugin:php": "composer lint",
    "release": "commit-and-tag-version --no-verify",
    "prepare": "husky"
  },
  "standard": {
    "parser": "babel-eslint"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.5",
    "@babel/preset-react": "^7.23.3",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.38.0",
    "@inquirer/prompts": "^7.9.0",
    "@prantlf/jsonlint": "^16.0.0",
    "@wordpress/babel-preset-default": "^4.8.0",
    "@wordpress/eslint-plugin": "^22.20.0",
    "@wordpress/stylelint-config": "^23.26.0",
    "babel-loader": "^9.1.3",
    "commit-and-tag-version": "^12.6.0",
    "css-loader": "^6.10.0",
    "eslint": "^8.57.1",
    "glob": "^7.2.3",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "kleur": "^4.1.5",
    "lint-staged": "^16.2.6",
    "mini-css-extract-plugin": "^0.11.2",
    "npm-run-all2": "^8.0.4",
    "sass": "^1.47.0",
    "sass-loader": "^16.0.6",
    "stylelint": "^16.25.0",
    "webpack": "^5.90.3",
    "webpack-cli": "^4.10.0",
    "webpack-manifest-plugin": "^5.0.0"
  }
}
